NODE_ENV=development
PORT=3001
API_URL=http://localhost:3001

# Database (PostgreSQL)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE"

# JWT Configuration (REQUIRED — server exits if not set)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# OpenAI API (required for OCR receipts and AI advisor)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Frontend URL — comma-separated allowlist for CORS (REQUIRED in production)
# Example: FRONTEND_URL=https://app.example.com,https://staging.example.com
FRONTEND_URL=http://localhost:3000

# Cron Secret — required for /api/cron/recurring to execute scheduled transactions
# Generate with: openssl rand -hex 32
# In Vercel, configure with the same value used in vercel.json cron headers
CRON_SECRET=replace_with_openssl_rand_hex_32

# Microsoft OAuth (Optional - Not used currently)
MICROSOFT_CLIENT_ID=your_microsoft_client_id
MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret
MICROSOFT_TENANT_ID=your_microsoft_tenant_id
MICROSOFT_REDIRECT_URI=http://localhost:3001/api/auth/callback

# SharePoint (Optional - Not used currently)
SHAREPOINT_SITE_ID=your_sharepoint_site_id
SHAREPOINT_FILE_ID=your_sharepoint_file_id

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads
